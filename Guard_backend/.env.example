PORT=9002

# Primary application database
MONGO_URI=your_mongodb_connection_uri

# External biometric database (source for attendance generation)
MONGO_URI1=your_biometric_mongodb_uri

# External attendance log API (manual today-attendance pull)
ATTENDANCE_LOG_API=http://host:port/api/get-attendance-main-log

# Biometric source config (read by scheduleController attendance generation)
BIOMETRIC_DB_NAME=technicalhub
BIOMETRIC_COLLECTION=attendancelogs
BIOMETRIC_DEVICE_SERIAL=your_device_serial
